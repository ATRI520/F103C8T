  12:Core/Src/sgp30.c **** #define SGP30_CMD_IAQ_MEAS_LSB  (0x08U)
  13:Core/Src/sgp30.c **** /* Datasheet: IAQ measure ready typ. 12 ms; margin + noisy bus */
